<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Payment Routing</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f0f12;
    --bg2: #18181f;
    --bg3: #22222d;
    --border: rgba(255,255,255,0.09);
    --text: #f0f0f8;
    --muted: #888899;
    --green: #34d669;
    --amber: #fbbf24;
    --blue: #60a5fa;
    --red: #f87171;
    --gray: #6b7280;
    --purple: #c084fc;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    min-height: 100vh;
    padding-bottom: 48px;
  }

  header {
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    padding: 18px 16px 14px;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  header h1 {
    font-size: 17px;
    font-weight: 800;
    letter-spacing: 0.04em;
    color: var(--text);
  }

  header p {
    font-size: 12px;
    color: var(--muted);
    margin-top: 2px;
    font-family: 'DM Mono', monospace;
  }

  .tabs {
    display: flex;
    gap: 2px;
    padding: 10px 12px;
    overflow-x: auto;
    scrollbar-width: none;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 57px;
    z-index: 99;
  }
  .tabs::-webkit-scrollbar { display: none; }

  .tab {
    flex-shrink: 0;
    padding: 8px 14px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    border: 1px solid transparent;
    background: transparent;
    color: var(--muted);
    transition: all 0.15s;
    white-space: nowrap;
  }
  .tab:hover { color: var(--text); }
  .tab.active { border-color: var(--border); background: var(--bg3); }
  .tab.active.t-green { color: var(--green); }
  .tab.active.t-amber { color: var(--amber); }
  .tab.active.t-blue  { color: var(--blue); }
  .tab.active.t-red   { color: var(--red); }
  .tab.active.t-purple{ color: var(--purple); }

  .panel { display: none; padding: 14px 14px; }
  .panel.active { display: block; }

  .cat-header {
    border-radius: 12px;
    padding: 14px 16px;
    margin-bottom: 12px;
  }
  .cat-header h2 { font-size: 19px; font-weight: 800; }
  .cat-header p { font-size: 13px; margin-top: 4px; line-height: 1.5; opacity: 0.85; }

  .ch-green { background: rgba(52,214,105,0.1); border: 1px solid rgba(52,214,105,0.25); color: var(--green); }
  .ch-amber { background: rgba(251,191,36,0.1); border: 1px solid rgba(251,191,36,0.25); color: var(--amber); }
  .ch-blue  { background: rgba(96,165,250,0.1); border: 1px solid rgba(96,165,250,0.25); color: var(--blue); }
  .ch-red   { background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.25); color: var(--red); }
  .ch-purple{ background: rgba(192,132,252,0.1); border: 1px solid rgba(192,132,252,0.25); color: var(--purple); }

  .bill-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px 16px;
    margin-bottom: 10px;
  }

  .bill-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 6px;
  }

  .bill-name {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    flex: 1;
  }

  .bill-amount {
    font-family: 'DM Mono', monospace;
    font-size: 18px;
    font-weight: 500;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .bill-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
    margin-bottom: 4px;
  }

  .pill {
    display: inline-block;
    padding: 3px 8px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    font-family: 'DM Mono', monospace;
    white-space: nowrap;
  }
  .pill-green { background: rgba(52,214,105,0.15); color: var(--green); }
  .pill-amber { background: rgba(251,191,36,0.15); color: var(--amber); }
  .pill-blue  { background: rgba(96,165,250,0.15); color: var(--blue); }
  .pill-red   { background: rgba(248,113,113,0.15); color: var(--red); }
  .pill-gray  { background: rgba(107,114,128,0.2); color: #9ca3af; }

  .reward-line {
    font-size: 13px;
    font-family: 'DM Mono', monospace;
    color: var(--muted);
  }
  .reward-line span { color: var(--text); font-weight: 500; }

  .bill-note {
    font-size: 13px;
    line-height: 1.55;
    color: #aaaabb;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid var(--border);
  }

  .faded { opacity: 0.5; }

  .reward-banner {
    border-radius: 14px;
    padding: 20px 18px;
    margin-bottom: 12px;
    text-align: center;
  }
  .rb-green { background: rgba(52,214,105,0.08); border: 1px solid rgba(52,214,105,0.2); }

  .rb-label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px; }
  .rb-val { font-family: 'DM Mono', monospace; font-size: 38px; font-weight: 500; }
  .rb-sub { font-size: 13px; color: var(--muted); margin-top: 4px; }

  .two-up { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 12px; }
  .mini-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px;
    text-align: center;
  }
  .mc-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
  .mc-val { font-family: 'DM Mono', monospace; font-size: 24px; font-weight: 500; }
  .mc-sub { font-size: 11px; color: var(--muted); margin-top: 2px; }

  .breakdown-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .breakdown-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 13px 16px;
    border-bottom: 1px solid var(--border);
  }
  .breakdown-row:last-child { border-bottom: none; }
  .br-label { font-size: 14px; font-weight: 600; flex: 1; padding-right: 10px; line-height: 1.4; }
  .br-val { font-family: 'DM Mono', monospace; font-size: 15px; font-weight: 500; white-space: nowrap; }

  .sec-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 14px 2px 8px;
  }

  .rule-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px 16px;
    margin-bottom: 10px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .rule-num {
    font-family: 'DM Mono', monospace;
    font-size: 18px;
    font-weight: 500;
    color: var(--amber);
    flex-shrink: 0;
    line-height: 1.4;
  }
  .rule-text {
    font-size: 14px;
    line-height: 1.6;
    color: #c8c8dc;
  }
  .rule-text strong { color: var(--text); font-weight: 700; }
</style>
</head>
<body>

<header>
  <h1>💳 Payment Routing</h1>
  <p>Jonathan's bills &amp; recurring spend</p>
</header>

<div class="tabs">
